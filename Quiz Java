package com.example.quizapp;

import android.content.Intent;
import android.graphics.Color;
import android.os.Bundle;
import android.os.Handler;
import android.view.View;
import android.widget.Button;
import android.widget.ProgressBar;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;

import com.example.quizapp.ResultActivity;

public class QuizActivity extends AppCompatActivity {

    // ── UI Elements ──────────────────────────────────────────
    TextView tvQuestion, tvQNum, tvScore;
    Button btnA, btnB, btnC, btnD;
    ProgressBar progressBar;

    // ── Quiz State ────────────────────────────────────────────
    int score = 0;
    int questionNumber = 1;
    String correctAnswer = "";

    // ── All 5 Questions ───────────────────────────────────────
    String[] questions = {
            "Who is called the God of Cricket?",
            "How many players are there in a cricket team?",
            "What is the full form of IPL?",
            "Which country won the 2011 Cricket World Cup?",
            "What is the highest individual score in ODI cricket by an Indian?"
    };

    String[] optionsA = { "A. Virat Kohli",    "A. 9",  "A. Indian Premier League",      "A. Australia", "A. 200*" };
    String[] optionsB = { "B. Sachin Tendulkar","B. 10", "B. International Play League",  "B. India",     "B. 183" };
    String[] optionsC = { "C. MS Dhoni",        "C. 11", "C. Indian Play League",          "C. Pakistan",  "C. 264" };
    String[] optionsD = { "D. Rohit Sharma",    "D. 12", "D. None of the above",           "D. Sri Lanka", "D. 175" };

    // Correct answer is the button label: "A", "B", "C", or "D"
    String[] answers   = { "B", "C", "A", "B", "A" };

    // ─────────────────────────────────────────────────────────
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_quiz);

        // Connect all UI elements
        tvQuestion  = findViewById(R.id.tvQuestion);
        tvQNum      = findViewById(R.id.tvQNum);
        tvScore     = findViewById(R.id.tvScore);
        progressBar = findViewById(R.id.progressBar);
        btnA        = findViewById(R.id.btnA);
        btnB        = findViewById(R.id.btnB);
        btnC        = findViewById(R.id.btnC);
        btnD        = findViewById(R.id.btnD);

        // Load first question
        loadQuestion();

        // Set click listeners for all 4 buttons
        btnA.setOnClickListener(v -> checkAnswer("A", btnA));
        btnB.setOnClickListener(v -> checkAnswer("B", btnB));
        btnC.setOnClickListener(v -> checkAnswer("C", btnC));
        btnD.setOnClickListener(v -> checkAnswer("D", btnD));
    }

    // Loads the current question and options onto the screen
    void loadQuestion() {
        int index = questionNumber - 1; // Array index starts at 0

        tvQuestion.setText(questions[index]);
        btnA.setText(optionsA[index]);
        btnB.setText(optionsB[index]);
        btnC.setText(optionsC[index]);
        btnD.setText(optionsD[index]);

        correctAnswer = answers[index];

        tvQNum.setText("Question " + questionNumber + " of 5");
        tvScore.setText("Score: " + score);
        progressBar.setProgress(questionNumber);

        // Reset button colors back to default
        resetButtonColors();

        // Re-enable all buttons
        setButtonsEnabled(true);
    }

    // Called when user taps any answer button
    void checkAnswer(String selected, Button clickedBtn) {
        // Disable all buttons so user can't tap again during feedback
        setButtonsEnabled(false);

        if (selected.equals(correctAnswer)) {
            // Correct answer → green highlight
            score++;
            clickedBtn.setBackgroundColor(Color.parseColor("#27AE60"));
        } else {
            // Wrong answer → red highlight on clicked, green on correct
            clickedBtn.setBackgroundColor(Color.parseColor("#C0392B"));
            highlightCorrectButton();
        }

        tvScore.setText("Score: " + score);

        // Wait 1 second then move to next question
        new Handler().postDelayed(() -> {
            questionNumber++;

            if (questionNumber > 5) {
                // All questions done → go to Result screen
                goToResult();
            } else {
                loadQuestion();
            }
        }, 1000); // 1000 ms = 1 second delay
    }

    // Highlights the correct answer button green
    void highlightCorrectButton() {
        switch (correctAnswer) {
            case "A": btnA.setBackgroundColor(Color.parseColor("#27AE60")); break;
            case "B": btnB.setBackgroundColor(Color.parseColor("#27AE60")); break;
            case "C": btnC.setBackgroundColor(Color.parseColor("#27AE60")); break;
            case "D": btnD.setBackgroundColor(Color.parseColor("#27AE60")); break;
        }
    }

    // Resets all button colors to default dark blue
    void resetButtonColors() {
        int defaultColor = Color.parseColor("#1E3A5F");
        btnA.setBackgroundColor(defaultColor);
        btnB.setBackgroundColor(defaultColor);
        btnC.setBackgroundColor(defaultColor);
        btnD.setBackgroundColor(defaultColor);
    }

    // Enable or disable all answer buttons
    void setButtonsEnabled(boolean enabled) {
        btnA.setEnabled(enabled);
        btnB.setEnabled(enabled);
        btnC.setEnabled(enabled);
        btnD.setEnabled(enabled);
    }

    // Opens the Result screen and passes the score
    void goToResult() {
        Intent intent = new Intent(QuizActivity.this, ResultActivity.class);
        intent.putExtra("SCORE", score); // Pass score to ResultActivity
        startActivity(intent);
        finish(); // Close QuizActivity so Back button doesn't return here
    }
}
